# A lot of this is directly from
# https://github.com/twpayne/dotfiles/blob/436e4e9366667d84493d3504123bb16c89583605/home/.chezmoi.toml.tmpl

{{/* boolean feature tags */}}
{{- $ephemeral := false -}}{{/* true if this machine is ephemeral, e.g. a cloud or VM instance */}}
{{- $headless := false -}}{{/* true if this machine does not have a screen and keyboard */}}
{{- $personal := false -}}{{/* true if this machine should have personal secrets */}}
{{- $wsl := false -}}{{/* true if this machine is running WSL2 */}}
{{- "" -}}

{{- $osID := .chezmoi.os -}}
{{- if (and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id")) -}}
{{-   $osID = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

{{/* detect GitHub codespaces, VSCode remote containers, Docker containers, Multipass VMs, and Vagrant boxes */}}
{{- if or (env "CODESPACES") (env "REMOTE_CONTAINERS_IPC") (eq .chezmoi.username "root" "ubuntu" "vagrant" "vscode") -}}
{{-   $ephemeral = true -}}
{{-   $headless = true -}}
{{- end -}}

{{- $hostname := .chezmoi.hostname -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $hostname = output "scutil" "--get" "ComputerName" | trim -}}
{{- end -}}

{{- if eq .chezmoi.os "windows" -}}
{{-   $ephemeral = true -}}
{{- end -}}

{{- if not $ephemeral -}}
{{-   if eq $hostname "bergamot" -}}
{{-     $headless = false -}}
{{-     $personal = true -}}
{{-   else if eq $hostname "calamansi" -}}
{{-     $headless = true -}}
{{-     $personal = false -}}
{{-   else if eq $hostname "kumquat" -}}
{{-     $headless = true -}}
{{-     $personal = false -}}
{{-   else if eq $hostname "rangpur" -}}
{{-     $headless = true -}}
{{-     $personal = false -}}
{{-   else if eq $hostname "tangelo" -}}
{{-     $headless = true -}}
{{-     $personal = false -}}
{{-   else if eq $hostname "miraclemax" -}}
{{-     $headless = false -}}
{{-     $personal = true -}}
{{-   else if eq $hostname "yuzu" -}}
{{-     $headless = false -}}
{{-     $personal = true -}}
{{-   else if eq $hostname "liquidity-ubuntu-wsl" -}}
{{-     $headless = false -}}
{{-     $personal = true -}}
{{-     $wsl = true -}}
{{-   else if eq $hostname "limon" -}}
{{-     $headless = false -}}
{{-     $personal = true -}}
{{-   else if stdinIsATTY -}}
{{-     $headless = promptBoolOnce . "headless" "headless" -}}
{{-     $ephemeral = promptBoolOnce . "ephemeral" "ephemeral" -}}
{{-   else -}}
{{-     $ephemeral = true -}}
{{-     $headless = true -}}
{{-     $personal = false -}}
{{-   end -}}
{{- end -}}

{{- $email := "ashebanow@gmail.com" -}}

[data]
    ephemeral = {{ $ephemeral }}
    email = {{ $email | quote }}
    headless = {{ $headless }}
    hostname = {{ $hostname | quote }}
    personal = {{ $personal }}
    bwsAccessToken = {{ (bitwarden "item" "BWS Chezmoi Access Token").notes | quote }}
{{- $bwsToken := .bwsAccessToken -}}
{{- $bwSecretID := "1cb8403e-118d-4c91-9877-b479004486f0" -}}
{{- $bwsBin := printf "%s/.local/share/mise/installs/bitwarden-secrets-manager/latest/bws" .chezmoi.homeDir -}}
{{- if $bwsToken -}}
{{-   $bwsCmd := printf "BWS_ACCESS_TOKEN=%s %s secret get %s 2>/dev/null || echo '{}'" $bwsToken $bwsBin $bwSecretID -}}
{{-   $secretJson := output "sh" "-c" $bwsCmd | fromJson -}}
{{-   $rawValue := index $secretJson "value" -}}
{{-   if $rawValue }}
{{-     $awkIdCmd := "cat <<'ENDOFBWS' | awk '/^client_id:/{getline; print; exit}'\n%s\nENDOFBWS\n" -}}
{{-     $clientId := output "sh" "-c" (printf $awkIdCmd $rawValue) | trim -}}
{{-     $awkSecretCmd := "cat <<'ENDOFBWS' | awk '/^client_secret:/{getline; print; exit}'\n%s\nENDOFBWS\n" -}}
{{-     $clientSecret := output "sh" "-c" (printf $awkSecretCmd $rawValue) | trim }}
    bwClientId = {{ $clientId | quote }}
    bwClientSecret = {{ $clientSecret | quote }}
{{-   end -}}
{{- end }}
    osid = {{ $osID | quote }}
    zshPlugins = [
      "vi-mode",
      "zsh-syntax-highlighting",
    ]

[github]
    refreshPeriod = "12h"
