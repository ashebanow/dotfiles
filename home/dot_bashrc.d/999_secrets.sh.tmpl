#############################################################################
# Password/Secret Management

export BITWARDEN_EMAIL=ashebanow@cattivi.com
export BWS_ACCESS_TOKEN="{{ .bwsAccessToken }}"

# Ensure bw (Bitwarden CLI) is unlocked, reusing a cached session file.
_bw_ensure_session() {
  command -v bw >/dev/null 2>&1 || return 0
  if [[ -n "${BW_SESSION:-}" ]] && BW_SESSION="$BW_SESSION" bw status >/dev/null 2>&1; then
    return 0
  fi
  local session_file="$HOME/.cache/bw-session"
  if [[ -f "$session_file" ]]; then
    local cached_session=$(cat "$session_file" 2>/dev/null)
    if [[ -n "$cached_session" ]] && BW_SESSION="$cached_session" bw status >/dev/null 2>&1; then
      export BW_SESSION="$cached_session"
      return 0
    fi
  fi
  [[ -t 0 ]] || return 0
  local session
  if session=$(bw unlock --raw 2>/dev/null); then
    export BW_SESSION="$session"
    mkdir -p "$(dirname "$session_file")"
    echo "$session" > "$session_file"
    chmod 600 "$session_file"
  fi
}
_bw_ensure_session

# Log in via API key if not already logged in (bypasses 2FA)
_bw_ensure_api_login() {
  command -v bw >/dev/null 2>&1 || return 0
  bw login --check >/dev/null 2>&1 && return 0
  local client_id="{{ .bwClientId }}"
  local client_secret="{{ .bwClientSecret }}"
  [[ -n "$client_id" && -n "$client_secret" ]] || return 0
  BW_CLIENTID="$client_id" BW_CLIENTSECRET="$client_secret" bw login --apikey >/dev/null 2>&1 || true
}
_bw_ensure_api_login

# Source cached BWS secrets (populated by .zshenv on interactive login)
if [[ -f "$HOME/.cache/env/bw_env.sh" ]]; then
  source "$HOME/.cache/env/bw_env.sh"
fi

# SSH agent socket
export SSH_AUTH_SOCK="{{- .chezmoi.homeDir -}}/.bitwarden-ssh-agent.sock"
if [[ ! -S "${SSH_AUTH_SOCK}" ]]; then
  echo "WARNING: SSH Agent socket does not exist!" >&2
  echo "Path: {{- .chezmoi.homeDir -}}/.bitwarden-ssh-agent.sock" >&2
fi
