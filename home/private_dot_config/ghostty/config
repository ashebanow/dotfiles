# ghostty +show-config --default --docs
# ghostty +list-themes
# ghostty +list-fonts

###########################################################
# Default shell
# command = /home/linuxbrew/.linuxbrew/bin/zsh --login --interactive
# command = /opt/homebrew/opt/zsh/bin/zsh --login --interactive

###########################################################
# FONTS

# first we clear the font list
font-family                     = ""
font-family                     = "MonaspiceAr NFM"
font-family                     = "MonaspiceArNerdFontMono"
font-family                     = "SauceCodePro NFM"
font-family                     = "SauceCodeProNerdFontMono"
font-family                     = "Symbols Nerd Font Mono"
font-family                     = "SymbolsNerdFontMono"

font-size                       = 15
window-inherit-font-size        = true
# font-feature                    = calt
# font-feature                    = dlig
# font-feature                    = ss05

###########################################################
# LOOK & FEEL

theme                           = dark:Gruvbox Dark Hard,light:Gruvbox Light Hard

macos-titlebar-proxy-icon       = hidden
macos-titlebar-style            = tabs
mouse-hide-while-typing         = true
# window-theme                  = ghostty

shell-integration              = detect
shell-integration-features     = cursor,sudo,title,no-cursor

###########################################################
# KEY BINDINGS

# this keybind is for Shift-Enter to work correctly in Claude Code:
keybind                        = shift+enter=text:\x1b\r

# for oh-my-pi:
keybind = alt+backspace=text:\x1b\x7f
#keybind = shift+enter=text:\n
