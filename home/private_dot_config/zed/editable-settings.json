// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    }
  },
  "ssh_connections": [
    {
      "host": "lumquat",
      "username": "podman",
      "args": [],
      "projects": [
        {
          "paths": ["/home/podman/nix-config"]
        }
      ]
    }
  ],
  "language_models": {
    "openai_compatible": {
      "LiteLLM": {
        "api_url": "https://litellm.fluffy-walleye.ts.net",
        "available_models": [
          {
            "name": "unsloth/Qwen3.6-35B-A3B-MTP-GGUF",
            "display_name": "Qwen 3.6 35B MOE",
            "max_tokens": 196000
          }
        ],
        "api_key": "sk-not-needed"
      },
      "MiniMax": {
        "api_url": "https://api.minimax.io/v1",
        "available_models": [
          {
            "name": "MiniMax-M2.7-highspeed",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          },
          {
            "name": "MiniMax-M3",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false
            }
          }
        ]
      }
    },
    "lmstudio": {
      "api_url": "http://localhost:1234/api/v0"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "auto_install_extensions": {
    "dockerfile": true,
    "docker-compose": true,
    "gem": true,
    "golangci-lint": true,
    "html": true,
    "java": true,
    "jinja2": true,
    "kdl": true,
    "lua": true,
    "make": true,
    "mcp-server-github": true,
    "nix": true,
    "proto": true,
    "ruby": true,
    "rust": true,
    "sql": true,
    "svelte": true,
    "toml": true
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "relative_line_numbers": "enabled",
  // Vim settings
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "gutters": {
    "min_line_number_digits": 3
  },
  "languages": {
    "Markdown": {
      "format_on_save": "on",
      "remove_trailing_whitespace_on_save": true
    }
  },
  "context_servers": {},
  "load_direnv": "shell_hook",
  "base_keymap": "VSCode",
  "vim_mode": true,
  "ui_font_size": 15,
  "buffer_font_family": "SauceCodePro Nerd Font",
  // Set the buffer text's font fallbacks, this will be merged with
  // the platform's default fallbacks.
  "buffer_font_fallbacks": ["Symbols Nerd Font"],
  "buffer_font_size": 16,
  "terminal": {
    "font_family": "SauceCodePro Nerd Font",
    "font_fallbacks": ["Symbols Nerd Font"],
    "font_size": 16
  },
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Hard",
    "dark": "Gruvbox Dark Hard"
  },
  "agent": {
    // Version of this setting.
    "favorite_models": [
      {
        "provider": "LiteLLM",
        "model": "unsloth/Qwen3.6-35B-A3B-MTP-GGUF",
        "enable_thinking": false
      },
      {
        "provider": "MiniMax",
        "model": "MiniMax-M3",
        "enable_thinking": false
      },
      {
        "provider": "deepseek",
        "model": "deepseek-v4-flash",
        "enable_thinking": true,
        "effort": "high"
      },
      {
        "provider": "deepseek",
        "model": "deepseek-v4-pro",
        "enable_thinking": true,
        "effort": "high"
      },
      {
        "provider": "google",
        "model": "gemini-3.5-flash",
        "enable_thinking": true,
        "effort": "medium"
      }
    ],
    "default_profile": "ask",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "deepseek",
      "model": "deepseek-v4-pro"
    },
    // Whether the agent is enabled.
    "enabled": true,
    /// What completion mode to start new threads in, if available. Can be 'normal' or 'max'.
    "preferred_completion_mode": "normal",
    // Whether to show the agent panel button in the status bar.
    "button": true,
    // Where to dock the agent panel. Can be 'left', 'right' or 'bottom'.
    "dock": "left",
    // Default width when the agent panel is docked to the left or right.
    "default_width": 640,
    // Default height when the agent panel is docked to the bottom.
    "default_height": 320,
    // When enabled, the agent will stream edits.
    "stream_edits": false,
    // When enabled, agent edits will be displayed in single-file editors for review
    "single_file_review": false,
    "enable_feedback": true,
    "notify_when_agent_waiting": "primary_screen"
  },
  "lsp": {
    "rust-analyzer": {
      "binary": {
        "path_lookup": true
      }
    },
    "nix": {
      "binary": {
        "path_lookup": true
      }
    }
  }
}
