# -----------------------------------------------------
# .zshrc — Main zsh configuration
# Per-topic configs are sourced from zshrc.d/
# -----------------------------------------------------

# Ensure path arrays are unique
typeset -U path cdpath fpath manpath

# Source all modular configs
for config_file ($ZDOTDIR/zshrc.d/*.zsh(N)); do
  source $config_file
done

# Compile .zshrc for faster startup
if [[ ! -f ~/.zshrc.zwc || ~/.zshrc -nt ~/.zshrc.zwc ]]; then
  zcompile ~/.zshrc
fi
