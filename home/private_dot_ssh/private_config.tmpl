# Managed by lazyssh

Host bergamot berg
    HostName bergamot

Host berg.*
    HostName bergamot
    RemoteCommand zmx attach %k
    RequestTTY yes

Host lum.*
    HostName lumquat
    User podman
    RemoteCommand zmx attach %k
    RequestTTY yes

Host lumquat lum
    HostName lumquat
    User podman

Host mm.*
    HostName miraclemax
    RemoteCommand zmx attach %k
    RequestTTY yes

Host miraclemax mm
    HostName miraclemax

Host limon li
    HostName limon

Host calamansi cala
    HostName calamansi

Host reverse-proxy
    User root

Host unifi
    User ubnt

Host storage
    User root

Host github.com github
    HostName ssh.github.com
    Port 443
    User git
    IdentityFile {{ .chezmoi.homeDir -}}/.ssh/github_ed25519

Host *
    User ashebanow
    IdentityFile {{ .chezmoi.homeDir -}}/.ssh/id_ed25519
    ControlMaster auto
    ControlPath ~/.ssh/controlmaster/%r@%h:%p
    ControlPersist yes
